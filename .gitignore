# Ultrapower plugin development repository — local runtime artifacts only.
# (These rules are for THIS plugin's repo; Ultrapower never edits a user
# application repo's .gitignore as part of normal operation.)

# CodeGraph local index
.codegraph/

# Ultrapower transient task state
.ultrapower/

# Claude Code local runtime lock (generated, not plugin source).
# Scoped to the known artifact so intentional committed .claude/ config is kept.
.claude/scheduled_tasks.lock
